  "description": "AI-powered learning platform backend API",
  "type": "commonjs",
  "main": "build/app.js",
  "scripts": {
    "start": "node build/app.js",
    "build": "tsc && cp src/swagger-output.json build/swagger-output.json",
    "dev": "nodemon --exec ts-node src/app.ts",
    "type-check": "tsc --noEmit",
