    "@types/multer": "^1.4.12",
    "@types/node": "^22.8.1",
    "@types/nodemailer": "^6.4.16",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.3"
